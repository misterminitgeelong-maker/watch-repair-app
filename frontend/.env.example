# Copy to `.env.local` for local overrides (not committed).

# Google Maps (browser key; optional)
# VITE_GOOGLE_MAPS_API_KEY=

# API origin when UI and API are on different hosts — scheme + host, no trailing slash.
# Example: https://mainspring.au
# Leave unset for normal web dev (Vite proxies /v1 to the backend) and same-origin Docker deploy.
# VITE_API_BASE_URL=

# Optional error reporting
# VITE_SENTRY_DSN=
