# ── Watch Repair App — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in production values.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (dev):     sqlite:////app/data/watch_repair.db
# PostgreSQL (prod): postgresql+psycopg://user:password@db:5432/mainspring
DATABASE_URL=postgresql+psycopg://watchrepair:changeme@db:5432/watchrepair

# ── JWT — generate with: openssl rand -hex 32 ─────────────────────────────────
JWT_SECRET=replace-with-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
JWT_REFRESH_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Mainspring API"
APP_ENV=production
ALLOW_PUBLIC_BOOTSTRAP=true       # Set to false after creating your first tenant
ALLOW_DEV_AUTO_LOGIN=false

# ── CORS & URLs ───────────────────────────────────────────────────────────────
CORS_ORIGINS=https://mainspring.au,https://www.mainspring.au
PUBLIC_BASE_URL=https://mainspring.au   # Used in SMS approval links (no trailing slash)

# ── Built frontend path (set automatically by Docker) ─────────────────────────
STATIC_DIR=/app/static

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
WEB_CONCURRENCY=2                 # uvicorn worker processes

# ── Startup seed (imports CSV only when DB has no repair jobs) ────────────────
STARTUP_SEED_ENABLED=false
STARTUP_SEED_CSV_PATH=seed/repairs_import.csv
STARTUP_SEED_TENANT_SLUG=myshop
STARTUP_SEED_TENANT_NAME=My Shop
STARTUP_SEED_OWNER_EMAIL=admin@myshop.com
STARTUP_SEED_OWNER_PASSWORD=change-me-strong-password   # ⚠ use a strong password

# ── Platform admin (optional cross-tenant visibility) ─────────────────────────
PLATFORM_ADMIN_ENABLED=false
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=                                # ⚠ use a strong password
PLATFORM_ADMIN_FULL_NAME=Platform Admin
PLATFORM_ADMIN_TENANT_SLUG=platform
PLATFORM_ADMIN_TENANT_NAME=Platform

# ── Twilio SMS (leave blank to disable) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=               # E.164 format, e.g. +61400000000

# ── Stripe billing (leave blank to disable) ───────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_BASE=
STRIPE_PRICE_BASIC_ADDON_TAB=
STRIPE_PRICE_PRO=

# ── Email notifications (leave blank/false to disable) ────────────────────────
ENABLE_EMAIL_NOTIFICATIONS=false
SENDGRID_API_KEY=
POSTMARK_API_KEY=

# ── Sentry error tracking (leave blank to disable) ────────────────────────────
SENTRY_DSN=

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_NEW_INVOICE_UI=true
ENABLE_CUSTOMER_PORTAL=true

# ── PostgreSQL container password (docker-compose only) ───────────────────────
POSTGRES_PASSWORD=changeme
