# ── Watch Repair App — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in production values.

# Database — use PostgreSQL for production
# SQLite:     sqlite:////app/data/watch_repair.db
# PostgreSQL: postgresql://watchrepair:PASSWORD@db:5432/watchrepair
DATABASE_URL=postgresql://watchrepair:changeme@db:5432/watchrepair

# JWT — CHANGE THIS to a random 64-char string (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-random-secret-string
JWT_EXPIRE_MINUTES=480
APP_ENV=production
ALLOW_PUBLIC_BOOTSTRAP=true
ALLOW_DEV_AUTO_LOGIN=false

# CORS — comma-separated allowed origins (no * in production). Web-only.
CORS_ORIGINS=https://mainspring.au,https://www.mainspring.au,https://localhost,http://localhost

# Public URL — used in SMS approval links (no trailing slash)
PUBLIC_BASE_URL=https://mainspring.au

# Built frontend path (set automatically by Docker, leave blank for dev)
STATIC_DIR=/app/static

# One-time startup seed (imports CSV only when DB has no repair jobs)
STARTUP_SEED_ENABLED=false
STARTUP_SEED_CSV_PATH=seed/repairs_import.csv
STARTUP_SEED_TENANT_SLUG=myshop
STARTUP_SEED_TENANT_NAME=My Shop
STARTUP_SEED_OWNER_EMAIL=admin@admin.com
STARTUP_SEED_OWNER_PASSWORD=Admin

# Optional testing tenant (no demo prompts; for internal QA)
TESTING_TENANT_SLUG=
TESTING_OWNER_EMAIL=
TESTING_OWNER_PASSWORD=

# Optional global platform admin (cross-tenant visibility)
PLATFORM_ADMIN_ENABLED=false
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=
PLATFORM_ADMIN_FULL_NAME=Platform Admin
PLATFORM_ADMIN_TENANT_SLUG=platform
PLATFORM_ADMIN_TENANT_NAME=Platform

# Twilio SMS (optional — leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Google Places API (optional — for Prospects search; leave blank to disable)
GOOGLE_PLACES_API_KEY=

# PostgreSQL container password (used by docker-compose)
POSTGRES_PASSWORD=changeme
