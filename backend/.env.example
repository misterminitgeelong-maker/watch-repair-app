# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit real credentials.

# Disable after first tenant is created in production.
ALLOW_PUBLIC_BOOTSTRAP=true

# Demo tenant (myshop) gets 20 Victorian B2B customer accounts seeded at startup.
# Restart the backend after code changes to refresh demo data.
# One-time startup seed (imports CSV only when DB has no repair jobs)
STARTUP_SEED_ENABLED=true
STARTUP_SEED_CSV_PATH=seed/repairs_import.csv
STARTUP_SEED_TENANT_SLUG=myshop
STARTUP_SEED_TENANT_NAME=My Shop
STARTUP_SEED_OWNER_EMAIL=admin@admin.com
STARTUP_SEED_OWNER_PASSWORD=Admin

# Optional testing tenant (no demo prompts; for internal QA)
# When set, creates testing tenant at startup. Sign in with these creds on /login.
# Set ALLOW_ENSURE_TESTING_TENANT=true to enable POST /auth/ensure-testing-tenant (force-create)
TESTING_TENANT_SLUG=testing
TESTING_OWNER_EMAIL=test@testing.com
TESTING_OWNER_PASSWORD=BIGFATTESTER
ALLOW_ENSURE_TESTING_TENANT=True

# Optional global platform admin (cross-tenant visibility)
PLATFORM_ADMIN_ENABLED=false
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=
PLATFORM_ADMIN_FULL_NAME=Platform Admin
PLATFORM_ADMIN_TENANT_SLUG=platform
PLATFORM_ADMIN_TENANT_NAME=Platform

# Twilio SMS (quote approvals, arrival notifications, etc.). E.164 format for numbers.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Stripe — same STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET for SaaS checkout and webhooks.
# Webhooks: customer.subscription.*, checkout.session.completed (Mobile invoices), and account.updated (Connect).
# Enable Stripe Connect in the Dashboard. Per-shop Mobile invoice card payments use Connect Express; settlement goes to each connected account.
# STRIPE_CONNECT_DEFAULT_COUNTRY=AU
ENABLE_STRIPE_INVOICE_CHECKOUT=true

# Full public URL of the frontend (used in SMS approval links)
PUBLIC_BASE_URL=https://mainspring.au

# Mobile Services: week/dispatch list filters and customer SMS use this IANA zone for “local” days (e.g. Australia/Sydney)
SCHEDULE_CALENDAR_TIMEZONE=Australia/Sydney

# Google Places API (optional — for Prospects search; leave blank to disable)
GOOGLE_PLACES_API_KEY=

# Google Maps Directions API — server-side driving order on Mobile Services → Map (leave blank to disable Driving mode)
# Can be the same GCP key as Places if Directions API is enabled for it.
# GOOGLE_MAPS_WEB_SERVICES_KEY=

# Google Maps JavaScript API key (for Mobile Services Map tab; Vite env — add to Railway as VITE_GOOGLE_MAPS_API_KEY)
# VITE_GOOGLE_MAPS_API_KEY=
