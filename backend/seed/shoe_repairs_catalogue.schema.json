{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shoe Repairs Catalogue Service Item",
  "type": "object",
  "properties": {
    "key": { "type": "string" },
    "name": { "type": "string" },
    "price": { "type": ["number", "null"] },
    "price_cents": { "type": ["integer", "null"] },
    "pricing_type": { "type": "string" },
    "notes": { "type": ["string", "null"] },
    "includes": { "type": ["array", "null"], "items": { "type": "string" } },
    "applicable_shoe_types": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "If null, service applies to all shoe types. If set, only applies to the listed shoe types. Canonical values: 'Dress shoes', 'Boots', 'Sneakers', 'Sandals / Thongs', 'Heels / Stilettos', 'Work boots', 'Birkenstocks', 'Other'"
    }
  },
  "required": ["key", "name", "price", "price_cents", "pricing_type"]
}
